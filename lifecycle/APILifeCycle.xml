<lifecycle>
    <aspect name="APILifeCycle" class="org.wso2.carbon.governance.registry.extensions.aspects.DefaultLifeCycle">
        <configuration type="literal">
            <lifecycle>
                <scxml xmlns="http://www.w3.org/2005/07/scxml" version="1.0" initialstate="Created">

                    <!-- ═══════════════════════════════════════════════════════════════
                         ESTADO: CREATED
                         API recién creado, pendiente de diseño y configuración
                    ═══════════════════════════════════════════════════════════════ -->
                    <state id="Created">
                        <datamodel>
                            <data name="checkItems">
                                <item name="Requirements" forEvent="">
                                    <item name="Rates and throttling levels applied" forEvent="Publish"/>
                                    <item name="Documentation provided" forEvent="Publish"/>
                                </item>
                            </data>
                            <data name="transitionExecution">
                                <execution forEvent="Publish" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                            </data>
                        </datamodel>
                        <transition event="Publish" target="Published"/>
                    </state>

                    <!-- ═══════════════════════════════════════════════════════════════
                         ESTADO: PUBLISHED
                         API publicado y disponible en el Gateway
                         Desde aquí se pueden registrar en entornos (UAT, NFT, PRO)
                    ═══════════════════════════════════════════════════════════════ -->
                    <state id="Published">
                        <datamodel>
                            <data name="transitionExecution">
                                <execution forEvent="Block" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                                <execution forEvent="Deprecate" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                                <execution forEvent="Demote to Created" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                                <!-- MVP: Ejecutores para registro en entornos -->
                                <execution forEvent="Register UAT" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                            </data>
                        </datamodel>
                        <!-- Transiciones estándar -->
                        <transition event="Block" target="Blocked"/>
                        <transition event="Deprecate" target="Deprecated"/>
                        <transition event="Demote to Created" target="Created"/>
                        <!-- MVP: Transición para registrar en UAT -->
                        <transition event="Register UAT" target="Registering UAT"/>
                    </state>

                    <!-- ═══════════════════════════════════════════════════════════════
                         ESTADO: REGISTERING UAT (Transitorio)
                         El API está siendo registrado en el repositorio Git de UAT
                         Este estado dispara el webhook al WSO2-Processor
                    ═══════════════════════════════════════════════════════════════ -->
                    <state id="Registering UAT">
                        <datamodel>
                            <data name="transitionExecution">
                                <execution forEvent="UAT Registration Complete" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                                <execution forEvent="UAT Registration Failed" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                            </data>
                        </datamodel>
                        <!-- El workflow externo cambiará el estado según resultado -->
                        <transition event="UAT Registration Complete" target="Registered UAT"/>
                        <transition event="UAT Registration Failed" target="Published"/>
                    </state>

                    <!-- ═══════════════════════════════════════════════════════════════
                         ESTADO: REGISTERED UAT
                         El API está registrado en Git para UAT
                         Desde aquí se puede promover a NFT
                    ═══════════════════════════════════════════════════════════════ -->
                    <state id="Registered UAT">
                        <datamodel>
                            <data name="transitionExecution">
                                <execution forEvent="Promote to NFT" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                                <execution forEvent="Demote to Published" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                            </data>
                        </datamodel>
                        <transition event="Promote to NFT" target="Promoting NFT"/>
                        <transition event="Demote to Published" target="Published"/>
                    </state>

                    <!-- ═══════════════════════════════════════════════════════════════
                         ESTADO: PROMOTING NFT (Transitorio)
                         El API está siendo promovido a NFT
                    ═══════════════════════════════════════════════════════════════ -->
                    <state id="Promoting NFT">
                        <datamodel>
                            <data name="transitionExecution">
                                <execution forEvent="NFT Promotion Complete" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                                <execution forEvent="NFT Promotion Failed" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                            </data>
                        </datamodel>
                        <transition event="NFT Promotion Complete" target="Registered NFT"/>
                        <transition event="NFT Promotion Failed" target="Registered UAT"/>
                    </state>

                    <!-- ═══════════════════════════════════════════════════════════════
                         ESTADO: REGISTERED NFT
                         El API está registrado en Git para NFT
                         Desde aquí se puede promover a PRO
                    ═══════════════════════════════════════════════════════════════ -->
                    <state id="Registered NFT">
                        <datamodel>
                            <data name="transitionExecution">
                                <execution forEvent="Promote to PRO" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                                <execution forEvent="Demote to UAT" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                            </data>
                        </datamodel>
                        <transition event="Promote to PRO" target="Promoting PRO"/>
                        <transition event="Demote to UAT" target="Registered UAT"/>
                    </state>

                    <!-- ═══════════════════════════════════════════════════════════════
                         ESTADO: PROMOTING PRO (Transitorio)
                         El API está siendo promovido a Producción
                    ═══════════════════════════════════════════════════════════════ -->
                    <state id="Promoting PRO">
                        <datamodel>
                            <data name="transitionExecution">
                                <execution forEvent="PRO Promotion Complete" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                                <execution forEvent="PRO Promotion Failed" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                            </data>
                        </datamodel>
                        <transition event="PRO Promotion Complete" target="Production"/>
                        <transition event="PRO Promotion Failed" target="Registered NFT"/>
                    </state>

                    <!-- ═══════════════════════════════════════════════════════════════
                         ESTADO: PRODUCTION
                         El API está en producción
                    ═══════════════════════════════════════════════════════════════ -->
                    <state id="Production">
                        <datamodel>
                            <data name="transitionExecution">
                                <execution forEvent="Deprecate" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                                <execution forEvent="Demote to NFT" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                            </data>
                        </datamodel>
                        <transition event="Deprecate" target="Deprecated"/>
                        <transition event="Demote to NFT" target="Registered NFT"/>
                    </state>

                    <!-- ═══════════════════════════════════════════════════════════════
                         ESTADOS ESTÁNDAR WSO2
                    ═══════════════════════════════════════════════════════════════ -->
                    <state id="Blocked">
                        <datamodel>
                            <data name="transitionExecution">
                                <execution forEvent="Re-Publish" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                                <execution forEvent="Deprecate" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                            </data>
                        </datamodel>
                        <transition event="Re-Publish" target="Published"/>
                        <transition event="Deprecate" target="Deprecated"/>
                    </state>

                    <state id="Deprecated">
                        <datamodel>
                            <data name="transitionExecution">
                                <execution forEvent="Retire" class="org.wso2.carbon.apimgt.impl.executors.APIExecutor"/>
                            </data>
                        </datamodel>
                        <transition event="Retire" target="Retired"/>
                    </state>

                    <state id="Retired">
                        <!-- Estado final -->
                    </state>

                </scxml>
            </lifecycle>
        </configuration>
    </aspect>
</lifecycle>
